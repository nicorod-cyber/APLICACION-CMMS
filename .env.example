# Copy to .env and replace every <...> value with a local secret. Do not commit .env.
POSTGRES_DB=cmms
POSTGRES_APP_USER=cmms_app
POSTGRES_APP_PASSWORD=<generate-a-strong-password>

CMMS_JWT_SECRET=<generate-at-least-32-random-characters>
CMMS_INITIAL_ADMIN_USERNAME=admin
CMMS_INITIAL_ADMIN_EMAIL=admin@example.local
CMMS_INITIAL_ADMIN_PASSWORD=<generate-a-strong-password>