ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

POSTGRES_DB=cmms
POSTGRES_APP_USER=cmms_app
POSTGRES_APP_PASSWORD=cmms_app_password

DataProvider__Provider=PostgreSql
DataProvider__ExcelPath=/app/data/excel
DataProvider__SqlServerConnectionString=
DataProvider__PostgreSqlConnectionString=Host=postgres;Port=5432;Database=cmms;Username=cmms_app;Password=cmms_app_password
Database__SeedDevelopment=true
DataProviders__Excel__BasePath=/app/data/excel
DataProviders__SqlServer__ConnectionStringName=CMMS_SQLSERVER
DataProviders__PostgreSql__ConnectionStringName=CMMS_POSTGRESQL

Jwt__Issuer=MaintenanceCMMS
Jwt__Audience=MaintenanceCMMS.Clients
Jwt__Secret=replace-with-at-least-32-characters
Jwt__ExpirationMinutes=60

Auth__SeedAdmin__Username=admin
Auth__SeedAdmin__Email=admin@example.local
Auth__SeedAdmin__DisplayName=Administrador CMMS
Auth__SeedAdmin__Password=ChangeMe.Admin123!

SharePoint__Provider=LocalSimulation
SharePoint__LocalPath=/app/data/sharepoint-simulated
SharePoint__ManualRootUrl=
SharePoint__SiteUrl=
SharePoint__TenantId=
SharePoint__ClientId=
SharePoint__SiteId=
SharePoint__DriveId=

Mail__Provider=Mailhog
Mail__From=cmms@example.local
Mail__PlanningEmail=planificacion@example.local
Mail__Host=mailhog
Mail__Port=1025

Pdf__TemplatePath=/app/data/templates
Pdf__Renderer=Html

PowerBI__DatasetPrefix=cmms
PowerBI__UseReportingViewsOnly=true

Offline__Enabled=true
Offline__SyncWindowDays=30

Imports__StoragePath=/app/data/imports
