{
  "DataProvider": {
    "Provider": "Excel",
    "ExcelPath": "data/excel",
    "SqlServerConnectionString": "",
    "PostgreSqlConnectionString": ""
  },
  "DataProviders": {
    "Excel": {
      "BasePath": "data/excel"
    },
    "SqlServer": {
      "ConnectionStringName": "CMMS_SQLSERVER"
    },
    "PostgreSql": {
      "ConnectionStringName": "CMMS_POSTGRESQL"
    }
  },
  "Jwt": {
    "Issuer": "MaintenanceCMMS",
    "Audience": "MaintenanceCMMS.Clients",
    "Secret": "",
    "ExpirationMinutes": 60
  },
  "Auth": {
    "SeedAdmin": {
      "Username": "",
      "Email": "",
      "DisplayName": "Administrador CMMS",
      "Password": "",
      "Faenas": []
    }
  },
  "SharePoint": {
    "Provider": "LocalSimulation",
    "LocalPath": "data/sharepoint-simulated",
    "ManualRootUrl": "",
    "SiteUrl": "",
    "TenantId": "",
    "ClientId": "",
    "SiteId": "",
    "DriveId": ""
  },
  "Mail": {
    "Provider": "Mailhog",
    "From": "cmms@example.local",
    "PlanningEmail": "planificacion@example.local",
    "Host": "localhost",
    "Port": 1025
  },
  "Pdf": {
    "TemplatePath": "data/templates",
    "Renderer": "Html"
  },
  "PowerBI": {
    "DatasetPrefix": "cmms",
    "UseReportingViewsOnly": true
  },
  "Offline": {
    "Enabled": true,
    "SyncWindowDays": 30
  },
  "Imports": {
    "StoragePath": "data/imports"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/maintenance-cmms-.log",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "AllowedHosts": "*"
}
